    {
      "parameters": {
        "jsCode": "const item = $input.first();\nreturn [{\n  json: {\n    ...item.json,\n    _success: item.json.ok === true\n  }\n}];"
      },
      "name": "Send Success?",
      "type": "n8n-nodes-base.code",
