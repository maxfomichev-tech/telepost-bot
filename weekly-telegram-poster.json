      ],
      "id": "if-success"
    },
    {
      "parameters": {
        "jsCode": "const post = $('Filter Posts').first()?.json;\nif (!post?.post_id) throw new Error('No post data from Filter Posts');\n\nreturn [{\n  json: {\n    id: post.post_id,\n    status: 'pending',\n    sent_at: new Date().toISOString(),\n    retry_count: 0\n  }\n}];"
      },
      "id": "mark-sent",
      "name": "Mark Sent",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1424,
        208
      ]
    },
    {
      "parameters": {
        "jsCode": "const post = $('Filter Posts').first()?.json;\nif (!post?.post_id) throw new Error('No post data from Filter Posts');\n\nconst item = $input.first();\nconst retryCount = (post.retry_count || 0) + 1;\nconst MAX_RETRIES = 3;\n\nreturn [{\n  json: {\n    id: post.post_id,\n    status: retryCount < MAX_RETRIES ? 'pending' : 'error',\n    retry_count: retryCount,\n    last_error: item.json?.error?.message || 'Telegram send failed'\n  }\n}];"
      },
